@implements IDisposable
@inject NavigationManager NavigationManager
@inject IAuthService AuthService 
@inject IDataService DataService
@inject IDataService DataService

<!-- Brand Header -->
<div class="flex items-center justify-between px-4 py-4 border-b border-slate-700 flex-shrink-0">
    <a href="" class="flex items-center gap-2.5 min-w-0">
        <div class="w-7 h-7 bg-indigo-600 rounded-md flex items-center justify-center flex-shrink-0">
            <i class="fas fa-desktop text-white" style="font-size: 0.65rem;"></i>
        </div>
        <div class="min-w-0">
            <div class="font-semibold text-slate-100 text-sm leading-tight truncate">
                @if (!string.IsNullOrWhiteSpace(_organization?.OrganizationName))
                {
                    @_organization.OrganizationName
                }
                else
                {
                    <span>Remotely</span>
                }
            </div>
            <div class="text-xs text-indigo-400 leading-tight mt-0.5">Support Portal</div>
        </div>
    </a>
    <button class="nav-toggler text-slate-400 hover:text-slate-100 transition-colors p-1 rounded" @onclick="ToggleNavMenu" aria-label="Toggle navigation">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
    </button>
</div>

<div class="@NavMenuCssClass nav-content" @onclick="ToggleNavMenu">
    <nav class="px-3 pt-3 pb-3 flex flex-col gap-0.5 flex-1">

        <NavLink class="nav-link sidebar-link" href="" Match="NavLinkMatch.All">
            <i class="fas fa-house nav-icon" aria-hidden="true"></i>
            <span>Home</span>
        </NavLink>

        <NavLink class="nav-link sidebar-link" href="downloads">
            <i class="fas fa-download nav-icon" aria-hidden="true"></i>
            <span>Downloads</span>
        </NavLink>

        <a class="sidebar-link" href="/Viewer" target="_blank">
            <i class="fas fa-desktop nav-icon" aria-hidden="true"></i>
            <span>Remote Control</span>
        </a>

        <AuthorizeView>
            <Authorized>
                <NavLink class="nav-link sidebar-link" href="deploy">
                    <i class="fas fa-upload nav-icon" aria-hidden="true"></i>
                    <span>Deploy</span>
                </NavLink>
                <NavLink class="nav-link sidebar-link" href="scripts">
                    <i class="fas fa-code nav-icon" aria-hidden="true"></i>
                    <span>Scripts</span>
                </NavLink>
                <NavLink class="nav-link sidebar-link" href="device-details">
                    <i class="fas fa-laptop nav-icon" aria-hidden="true"></i>
                    <span>Device Details</span>
                </NavLink>
                <NavLink class="nav-link sidebar-link" href="user-options">
                    <i class="fas fa-sliders nav-icon" aria-hidden="true"></i>
                    <span>User Options</span>
                </NavLink>
                <NavLink class="nav-link sidebar-link" href="backup">
                    <i class="fas fa-hard-drive nav-icon" aria-hidden="true"></i>
                    <span>Backup</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        @if (_user?.IsAdministrator == true)
        {
            <div class="pt-4 pb-1 px-1">
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Admin</span>
            </div>

            <NavLink class="nav-link sidebar-link" href="manage-organization">
                <i class="fas fa-building nav-icon" aria-hidden="true"></i>
                <span>Organization</span>
            </NavLink>
            <NavLink class="nav-link sidebar-link" href="branding">
                <i class="fas fa-palette nav-icon" aria-hidden="true"></i>
                <span>Branding</span>
            </NavLink>
            <NavLink class="nav-link sidebar-link" href="api-keys">
                <i class="fas fa-key nav-icon" aria-hidden="true"></i>
                <span>API Keys</span>
            </NavLink>

            @if (_user?.IsServerAdmin == true)
            {
                <NavLink class="nav-link sidebar-link" href="server-logs">
                    <i class="fas fa-file-lines nav-icon" aria-hidden="true"></i>
                    <span>Server Logs</span>
                </NavLink>
                <NavLink class="nav-link sidebar-link" href="server-config">
                    <i class="fas fa-gear nav-icon" aria-hidden="true"></i>
                    <span>Server Config</span>
                </NavLink>
            }
        }

        <!-- Bottom section pinned to end of sidebar -->
        <div class="mt-auto pt-3 border-t border-slate-700 flex flex-col gap-0.5">
            <AuthorizeView>
                <Authorized>
                    <a class="sidebar-link" href="Account/Manage">
                        <i class="fas fa-user-circle nav-icon" aria-hidden="true"></i>
                        <span>Account</span>
                    </a>
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@_currentUrl" />
                        <button type="submit" class="sidebar-link w-full text-left">
                            <i class="fas fa-right-from-bracket nav-icon" aria-hidden="true"></i>
                            <span>Logout</span>
                        </button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a class="sidebar-link" href="Account/Login">
                        <i class="fas fa-right-to-bracket nav-icon" aria-hidden="true"></i>
                        <span>Log in</span>
                    </a>
                    @if (_isRegistrationEnabled)
                    {
                        <a class="sidebar-link" href="Account/Register">
                            <i class="fas fa-user-plus nav-icon" aria-hidden="true"></i>
                            <span>Register</span>
                        </a>
                    }
                </NotAuthorized>
            </AuthorizeView>
            <a class="sidebar-link" href="/about">
                <i class="fas fa-circle-info nav-icon" aria-hidden="true"></i>
                <span>About</span>
            </a>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool _isRegistrationEnabled;
    private RemotelyUser? _user;
    private Organization? _organization;
    private string? _currentUrl;

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        var settings = await DataService.GetSettings();
        _isRegistrationEnabled = settings.MaxOrganizationCount < 0 || DataService.GetOrganizationCount() < settings.MaxOrganizationCount;

        await base.OnInitializedAsync();

        _currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;

        var userResult = await AuthService.GetUser();

        if (!userResult.IsSuccess)
        {
            return;
        }

        _user = userResult.Value;

        if (!string.IsNullOrWhiteSpace(_user?.OrganizationID))
        {
            var orgResult = await DataService.GetOrganizationById(_user.OrganizationID);
            if (orgResult.IsSuccess)
            {
                _organization = orgResult.Value;
            }
        }
        else
        {
            var orgResult = await DataService.GetDefaultOrganization();
            if (orgResult.IsSuccess)
            {
                _organization = orgResult.Value;
            }
        }
    }

    private string NavMenuCssClass => collapseNavMenu ? "nav-hidden" : "";


    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        InvokeAsync(StateHasChanged);
    }
}
