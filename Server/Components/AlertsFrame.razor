@inherits AuthComponentBase
@attribute [Authorize]
@inject IDataService DataService 
@inject IModalService ModalService 

<button id="alertsButton"
        class="flex items-center gap-1.5 bg-[#291d38] hover:bg-[#1d1330] border border-white/10 text-[#c4b8d8] rounded-lg px-3 py-1.5 text-sm transition-colors shadow-lg"
        @onclick="ToggleOpen">
    <svg class="h-4 w-4 text-[#8b6cf7]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
    </svg>
    <span id="alertsCount" class="text-xs font-bold">@_alerts.Count</span>
</button>

<div id="alertsFrame" class="bg-[#160c22] border-l border-white/10 @FrameClass">
    <div class="flex items-center justify-between px-4 pt-4 pb-3 border-b border-white/10">
        <h3 class="text-white text-sm font-semibold">Alerts</h3>
        <div class="flex items-center gap-2">
            <button id="clearAllAlertsButton"
                    class="text-[#9b8eb5] hover:text-white text-xs transition-colors"
                    @onclick="ClearAllAlerts">
                Clear all
            </button>
            <button id="closeAlertsFrameButton"
                    class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#9b8eb5] rounded-lg p-1 transition-colors"
                    @onclick="ToggleOpen">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    </div>

    <div id="alertsBody" class="p-3 space-y-3">
        @foreach (var alert in _alerts)
        {
            <div @key="alert.ID" id="@alert.ID" class="bg-[#1d1330] border border-white/10 rounded-xl p-4">
                <div class="text-[#5e4d73] text-xs mb-1">@alert.CreatedOn.ToString()</div>
                <div class="text-[#c4b8d8] text-sm font-semibold mb-1">@alert.Device?.DeviceName</div>
                <p class="text-[#9b8eb5] text-xs mb-3">@alert.Message</p>

                @if (!string.IsNullOrWhiteSpace(alert.Details))
                {
                    <button class="text-[#8b6cf7] hover:text-[#a88cff] text-xs underline-offset-2 hover:underline transition-colors mb-2"
                            type="button"
                            @onclick="() => ShowAlertDetails(alert)">
                        View Details
                    </button>
                }

                <div class="text-right">
                    <button alert="@alert.ID"
                            class="alert-dismiss-button bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] rounded-lg px-3 py-1 text-xs transition-colors"
                            type="button"
                            @onclick="()=> { _ = ClearAlert(alert); }">
                        Dismiss
                    </button>
                </div>
            </div>
        }
        @if (_alerts.Count == 0)
        {
            <div class="text-center py-8 text-[#5e4d73] text-sm">No alerts.</div>
        }
    </div>
</div>

@code {
    private readonly List<Alert> _alerts = new();
    private bool _isOpen;

    private string? FrameClass => _isOpen ? "open" : null;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        EnsureUserSet();
        GetAlerts();
    }

    private async Task ClearAlert(Alert alert)
    {
        await DataService.DeleteAlert(alert);
        _alerts.Remove(alert);
    }

    private async Task ClearAllAlerts()
    {
        EnsureUserSet();
        await DataService.DeleteAllAlerts(User.OrganizationID, User.UserName);
        _alerts.Clear();
    }

    private void GetAlerts()
    {
        EnsureUserSet();
        _alerts.Clear();
        var alerts = DataService.GetAlerts(User.Id);
        if (alerts.Any())
        {
            _alerts.AddRange(alerts);
        }
    }

    private void ShowAlertDetails(Alert alert)
    {
        var body = alert.Details?.Split('\n') ?? Array.Empty<string>();
        ModalService.ShowModal($"Alert Details for {alert.Device?.DeviceName}", body);
    }

    private void ToggleOpen()
    {
        _isOpen = !_isOpen;
    }
}
