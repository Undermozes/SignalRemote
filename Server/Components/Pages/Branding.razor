@page "/branding"
@inherits AuthComponentBase
@attribute [Authorize(Policy = PolicyNames.OrganizationAdminRequired)]
@inject IDataService DataService
@inject IToastService ToastService
@inject IJsInterop JsInterop
@using Remotely.Server.Models
@using System.ComponentModel.DataAnnotations

<PageTitle>Branding &mdash; SignalRemote</PageTitle>

<div class="max-w-xl px-4 py-8">
    <h1 class="text-white text-2xl font-semibold mb-1">Branding</h1>
    <p class="text-[#9b8eb5] text-sm mb-6">Customize the product name and icon shown to your clients.</p>

    <AlertBanner Message="@_alertMessage" OnClose="() => _alertMessage = null" />

    <div class="bg-[#1d1330] border border-white/10 rounded-xl p-6 shadow-xl">
        <EditForm OnValidSubmit="HandleValidSubmit" Model="_inputModel">
            <DataAnnotationsValidator />

            <div class="space-y-5">
                <div>
                    <label class="block text-sm font-medium text-[#c4b8d8] mb-1.5">Product name</label>
                    <InputText class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-4 py-2.5 text-sm outline-none focus:border-[#7c5cbf] focus:ring-2 focus:ring-[#7c5cbf]/30 transition-all placeholder-white/30"
                               @bind-Value="_inputModel.ProductName" placeholder="Your product name" />
                    <ValidationMessage For="() => _inputModel.ProductName" class="block mt-1.5 text-xs text-red-400" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-[#c4b8d8] mb-3">Current icon</label>
                    <div class="inline-block bg-[#291d38] border border-white/10 rounded-xl p-3">
                        @if (!string.IsNullOrWhiteSpace(_base64Icon))
                        {
                            <img class="w-16 h-16 object-contain" src="data:image/png;base64,@_base64Icon" alt="Brand icon" />
                        }
                        else
                        {
                            <img class="w-16 h-16 object-contain" src="/images/Remotely_Icon.png" alt="Default icon" />
                        }
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-[#c4b8d8] mb-1.5">Upload new icon <span class="text-[#5e4d73]">(PNG, max 1 MB)</span></label>
                    <InputFile type="file" accept="image/png"
                               class="block w-full text-sm text-[#9b8eb5] file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-[#6c5fc7] file:text-white hover:file:bg-[#7c6fd7] file:cursor-pointer cursor-pointer"
                               OnChange="IconUploadInputChanged" />
                </div>
            </div>

            <div class="flex items-center gap-3 mt-6 pt-5 border-t border-white/10">
                <button class="bg-[#6c5fc7] hover:bg-[#7c6fd7] text-white font-semibold rounded-lg py-2.5 px-5 text-sm transition-colors" type="submit">
                    Save branding
                </button>
                <button class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] font-medium rounded-lg py-2.5 px-5 text-sm transition-colors"
                        type="button" @onclick="ResetBranding">
                    Reset to default
                </button>
            </div>
        </EditForm>
    </div>
</div>
@code {
    private string? _alertMessage;
    private string? _base64Icon;
    private InputModel _inputModel = new();

    private class InputModel
    {
        [StringLength(25)]
        [Required]
        [Display(Name = "Product Name")]
        public string ProductName { get; set; } = string.Empty;

        public byte[] IconBytes { get; set; } = Array.Empty<byte>();
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        await LoadBrandingInfo();
    }

    private async Task HandleValidSubmit(EditContext context)
    {
        EnsureUserSet();

        await DataService.UpdateBrandingInfo(
            User.OrganizationID,
            _inputModel.ProductName,
            _inputModel.IconBytes);

        if (_inputModel?.IconBytes?.Any() == true)
        {
            _base64Icon = Convert.ToBase64String(_inputModel.IconBytes);
        }

        _alertMessage = "Branding saved.";
        ToastService.ShowToast("Branding saved.");
    }

    private async Task IconUploadInputChanged(InputFileChangeEventArgs args)
    {
        if (args.File is null)
        {
            return;
        }

        if (args.File.Size > 1_024_000)
        {
            ToastService.ShowToast("File size must be under 1 MB.", classString: "bg-warning");
            return;
        }

        using var rs = args.File.OpenReadStream(1_024_000);
        _inputModel.IconBytes = new byte[args.File.Size];
        await rs.ReadAsync(_inputModel.IconBytes, 0, (int)args.File.Size);
    }

    private async Task LoadBrandingInfo()
    {
        var orgResult = await DataService.GetOrganizationByUserName($"{UserName}");

        if (!orgResult.IsSuccess)
        {
            ToastService.ShowToast2(orgResult.Reason, ToastType.Warning);
            return;
        }

        var brandingResult = await DataService.GetBrandingInfo(orgResult.Value.ID);

        if (!brandingResult.IsSuccess)
        {
            ToastService.ShowToast2(brandingResult.Reason, ToastType.Warning);
            return;
        }
        var brandingInfo = brandingResult.Value;

        _inputModel.ProductName = brandingInfo.Product;

        if (brandingResult.Value?.Icon?.Any() == true)
        {
            _base64Icon = Convert.ToBase64String(brandingInfo.Icon);
        }
    }

    private async Task ResetBranding()
    {
        EnsureUserSet();
        var result = await JsInterop.Confirm("Are you sure you want to reset branding to default?");
        if (result)
        {
            await DataService.ResetBranding(User.OrganizationID);
            _base64Icon = string.Empty;
            await LoadBrandingInfo();
            ToastService.ShowToast("Branding reset.");
        }
    }
}
