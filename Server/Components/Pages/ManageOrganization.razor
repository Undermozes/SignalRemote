@page "/manage-organization"
@attribute [Authorize(Policy = PolicyNames.OrganizationAdminRequired)]
@inherits AuthComponentBase

<h1 class="text-white text-2xl font-semibold mb-1">Manage Organization</h1>
<p class="text-[#9b8eb5] text-sm mb-6">Configure your organization settings, device groups, users, and invitations.</p>

@if (_isLoading)
{
    <p class="text-[#9b8eb5] text-sm animate-pulse">Loading...</p>
}
else if (User is not null)
{
    @* Organization Settings Card *@
    <div class="bg-[#1d1330] border border-white/10 rounded-xl p-6 mb-6">
        <h2 class="text-[#c4b8d8] text-sm font-semibold mb-4">Organization Settings</h2>

        @* Organization ID *@
        <div class="mb-4">
            <label class="text-[#c4b8d8] text-sm font-medium block mb-1.5">Organization ID</label>
            <input readonly
                   class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-4 py-2.5 text-sm outline-none placeholder-white/30"
                   value="@_organization?.ID" />
        </div>

        @* Organization Name *@
        <div class="mb-4">
            <label class="text-[#c4b8d8] text-sm font-medium block mb-1.5">Organization Name</label>
            <input @onchange="OrganizationNameChanged"
                   value="@_organization?.OrganizationName"
                   maxlength="25"
                   placeholder="Enter a name for your organization"
                   autocomplete="off"
                   class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-4 py-2.5 text-sm outline-none focus:border-[#7c5cbf] focus:ring-2 focus:ring-[#7c5cbf]/30 transition-all placeholder-white/30" />
            <p class="text-[#9b8eb5] text-xs mt-1.5">* Requires browser refresh.</p>
        </div>

        @if (User.IsServerAdmin)
        {
            @* Default Organization *@
            <div class="flex items-center gap-3">
                <input type="checkbox"
                       checked="@_organization?.IsDefaultOrganization"
                       @onchange="DefaultOrgCheckChanged"
                       class="accent-[#7c5cbf] cursor-pointer w-4 h-4" />
                <label class="text-[#c4b8d8] text-sm font-medium">Default Organization For Server</label>
                <button class="w-6 h-6 rounded-full bg-[#291d38] border border-white/10 flex items-center justify-center text-[#9b8eb5] hover:text-white text-xs transition-colors"
                        @onclick="ShowDefaultOrgHelp"
                        title="Help">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                </button>
            </div>
        }
    </div>

    @* Device Groups Card *@
    <div class="bg-[#1d1330] border border-white/10 rounded-xl p-6 mb-6">
        <div class="flex items-center gap-2 mb-4">
            <h2 class="text-[#c4b8d8] text-sm font-semibold">Device Groups</h2>
            <button class="w-6 h-6 rounded-full bg-[#291d38] border border-white/10 flex items-center justify-center text-[#9b8eb5] hover:text-white text-xs transition-colors"
                    @onclick="ShowDeviceGroupHelp"
                    title="Help">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </button>
        </div>

        <select class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-4 py-2.5 text-sm outline-none focus:border-[#7c5cbf] focus:ring-2 focus:ring-[#7c5cbf]/30 transition-all mb-3"
                @bind="_selectedDeviceGroupId"
                size="4">
            @foreach (var deviceGroup in _deviceGroups)
            {
                <option @key="deviceGroup.ID" value="@deviceGroup.ID">@deviceGroup.Name</option>
            }
        </select>

        <div class="flex justify-end mb-4">
            <button type="button"
                    class="bg-red-500/90 hover:bg-red-500 text-white font-semibold rounded-lg py-2 px-4 text-sm transition-colors"
                    @onclick="DeleteSelectedDeviceGroup">
                Delete
            </button>
        </div>

        <div class="flex gap-2">
            <input placeholder="Add new device group"
                   maxlength="200"
                   @bind="_newDeviceGroupName"
                   @bind:event="oninput"
                   @onkeypress="EvaluateNewDeviceGroupKeyPress"
                   class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-4 py-2.5 text-sm outline-none focus:border-[#7c5cbf] focus:ring-2 focus:ring-[#7c5cbf]/30 transition-all placeholder-white/30" />
            <button type="submit"
                    class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] font-medium rounded-lg py-2 px-4 text-sm transition-colors whitespace-nowrap"
                    @onclick="CreateNewDeviceGroup">
                Add
            </button>
        </div>
    </div>

    @* Users Card *@
    <div class="bg-[#1d1330] border border-white/10 rounded-xl p-6 mb-6">
        <div class="flex items-center gap-2 mb-4">
            <h2 class="text-[#c4b8d8] text-sm font-semibold">Users</h2>
            <button class="w-6 h-6 rounded-full bg-[#291d38] border border-white/10 flex items-center justify-center text-[#9b8eb5] hover:text-white text-xs transition-colors"
                    @onclick="ShowUsersHelp"
                    title="Help">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </button>
        </div>

        <div class="bg-[#1d1330] border border-white/10 rounded-xl overflow-hidden">
            <table class="w-full text-sm">
                <thead class="border-b border-white/10">
                    <tr>
                        <th class="text-left text-xs font-semibold text-[#9b8eb5] px-4 py-3">User Name</th>
                        <th class="text-left text-xs font-semibold text-[#9b8eb5] px-4 py-3">Administrator</th>
                        <th class="text-left text-xs font-semibold text-[#9b8eb5] px-4 py-3">Device Groups</th>
                        <th class="text-left text-xs font-semibold text-[#9b8eb5] px-4 py-3">Reset Password</th>
                        <th class="text-left text-xs font-semibold text-[#9b8eb5] px-4 py-3">Delete User</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var orgUser in _orgUsers)
                    {
                        <tr @key="orgUser.Id" class="border-b border-white/5 hover:bg-white/[0.02]">
                            <td class="text-[#c4b8d8] px-4 py-3">@orgUser.UserName</td>
                            @if (User.Id == orgUser.Id)
                            {
                                <td class="text-[#c4b8d8] px-4 py-3">
                                    <input type="checkbox" readonly disabled checked="@orgUser.IsAdministrator" class="accent-[#7c5cbf] cursor-pointer" />
                                </td>
                                <td class="text-[#c4b8d8] px-4 py-3">
                                    <button type="button"
                                            class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] font-medium rounded-lg py-2 px-4 text-sm transition-colors"
                                            title="Edit"
                                            @onclick="() => EditDeviceGroups(orgUser)">
                                        Edit
                                    </button>
                                </td>
                                <td class="text-[#c4b8d8] px-4 py-3"></td>
                                <td class="text-[#c4b8d8] px-4 py-3">
                                    <button type="button"
                                            class="bg-red-500/90 text-white font-semibold rounded-lg py-2 px-4 text-sm opacity-50 cursor-not-allowed"
                                            disabled>
                                        Delete
                                    </button>
                                </td>
                            }
                            else
                            {
                                <td class="text-[#c4b8d8] px-4 py-3">
                                    <input type="checkbox" @onchange="(ev) => SetUserIsAdmin(ev, orgUser)" checked="@orgUser.IsAdministrator" class="accent-[#7c5cbf] cursor-pointer" />
                                </td>
                                <td class="text-[#c4b8d8] px-4 py-3">
                                    <button type="button"
                                            class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] font-medium rounded-lg py-2 px-4 text-sm transition-colors"
                                            title="Edit"
                                            @onclick="() => EditDeviceGroups(orgUser)">
                                        Edit
                                    </button>
                                </td>
                                <td class="text-[#c4b8d8] px-4 py-3">
                                    <button type="button"
                                            class="bg-red-500/90 hover:bg-red-500 text-white font-semibold rounded-lg py-2 px-4 text-sm transition-colors"
                                            title="Reset Password"
                                            @onclick="() => ResetPassword(orgUser)">
                                        Reset
                                    </button>
                                </td>
                                <td class="text-[#c4b8d8] px-4 py-3">
                                    <button type="button"
                                            class="bg-red-500/90 hover:bg-red-500 text-white font-semibold rounded-lg py-2 px-4 text-sm transition-colors"
                                            title="Delete User"
                                            @onclick="() => DeleteUser(orgUser)">
                                        Delete
                                    </button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Invitations Card *@
    <div class="bg-[#1d1330] border border-white/10 rounded-xl p-6 mb-6">
        <div class="flex items-center gap-2 mb-4">
            <h2 class="text-[#c4b8d8] text-sm font-semibold">Invitations</h2>
            <button class="w-6 h-6 rounded-full bg-[#291d38] border border-white/10 flex items-center justify-center text-[#9b8eb5] hover:text-white text-xs transition-colors"
                    @onclick="ShowInvitesHelp"
                    title="Help">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </button>
        </div>

        <div class="bg-[#1d1330] border border-white/10 rounded-xl overflow-hidden">
            <table id="invitesTable" class="w-full text-sm">
                <thead class="border-b border-white/10">
                    <tr>
                        <th class="text-left text-xs font-semibold text-[#9b8eb5] px-4 py-3">Invited User</th>
                        <th class="text-left text-xs font-semibold text-[#9b8eb5] px-4 py-3">Administrator</th>
                        <th class="text-left text-xs font-semibold text-[#9b8eb5] px-4 py-3">Link(s)</th>
                        <th class="text-left text-xs font-semibold text-[#9b8eb5] px-4 py-3">Delete</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invite in _invites)
                    {
                        <tr @key="invite.ID" class="border-b border-white/5 hover:bg-white/[0.02]">
                            <td class="text-[#c4b8d8] px-4 py-3">@invite.InvitedUser</td>
                            <td class="text-[#c4b8d8] px-4 py-3">
                                <input type="checkbox" checked="@invite.IsAdmin" disabled class="accent-[#7c5cbf] cursor-pointer" />
                            </td>
                            <td class="text-[#c4b8d8] px-4 py-3">
                                <a href="@(NavManager.BaseUri)Invite/@invite.ID"
                                   class="text-[#7c5cbf] hover:text-[#9b8eb5] transition-colors underline underline-offset-2">
                                    Join Link
                                </a>
                            </td>
                            <td class="text-[#c4b8d8] px-4 py-3">
                                <button type="button"
                                        class="bg-red-500/90 hover:bg-red-500 text-white font-semibold rounded-lg py-2 px-4 text-sm transition-colors"
                                        invite="@invite.ID"
                                        @onclick="() => DeleteInvite(invite)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Add User Card *@
    <div class="bg-[#1d1330] border border-white/10 rounded-xl p-6 mb-6">
        <h2 class="text-[#c4b8d8] text-sm font-semibold mb-4">Add User</h2>

        <div class="flex gap-2 flex-wrap items-center">
            <input @bind="_inviteEmail"
                   @bind:event="oninput"
                   placeholder="Email of user to add"
                   type="email"
                   required
                   class="flex-1 min-w-0 bg-[#291d38] border border-white/10 text-white rounded-lg px-4 py-2.5 text-sm outline-none focus:border-[#7c5cbf] focus:ring-2 focus:ring-[#7c5cbf]/30 transition-all placeholder-white/30" />

            <label class="flex items-center gap-2 text-[#c4b8d8] text-sm font-medium whitespace-nowrap">
                <input @bind="_inviteAsAdmin"
                       type="checkbox"
                       @onkeypress="EvaluateInviteInputKeypress"
                       class="accent-[#7c5cbf] cursor-pointer w-4 h-4" />
                Admin?
            </label>

            <button type="button"
                    class="bg-[#6c5fc7] hover:bg-[#7c6fd7] text-white font-semibold rounded-lg py-2 px-4 text-sm transition-colors"
                    @onclick="SendInvite">
                Add
            </button>
        </div>
    </div>

}