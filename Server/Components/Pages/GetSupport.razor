@page "/get-support/{deviceId?}"
@using System.ComponentModel.DataAnnotations

@inject IDataService DataService
@inject IEmailSenderEx EmailSender

<PageTitle>Get Support &mdash; SignalRemote</PageTitle>

<div class="max-w-lg mx-auto px-4 py-10">

@if (string.IsNullOrWhiteSpace(DeviceId))
{
    <div class="bg-[#1d1330] border border-white/10 rounded-2xl p-8 shadow-xl text-center">
        <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center mx-auto mb-4">
            <svg class="h-6 w-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <h2 class="text-white text-lg font-semibold mb-2">Device ID Missing</h2>
        <p class="text-[#9b8eb5] text-sm">Please use a valid support shortcut that includes the device ID.</p>
    </div>
}
else
{
    <div class="bg-[#1d1330] border border-white/10 rounded-2xl p-8 shadow-xl">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-[#6c5fc7]/15 border border-[#6c5fc7]/30 flex items-center justify-center flex-shrink-0">
                <svg class="h-5 w-5 text-[#8b6cf7]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
            </div>
            <div>
                <h1 class="text-white text-xl font-semibold">Get Support</h1>
                <p class="text-[#9b8eb5] text-xs mt-0.5">Submit a support request to the IT team</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="@(_alertClass.Contains("danger")
                ? "flex items-start gap-3 bg-red-500/10 border border-red-500/30 text-red-300 text-sm rounded-lg px-4 py-3 mb-5"
                : "flex items-start gap-3 bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 text-sm rounded-lg px-4 py-3 mb-5")"
                 role="alert">
                <svg class="h-4 w-4 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span>@_statusMessage</span>
            </div>
        }

        <EditForm Model="Input" OnValidSubmit="OnValidSubmitAsync">
            <DataAnnotationsValidator />

            <div class="space-y-4">
                <div>
                    <label for="name" class="block text-sm font-medium text-[#c4b8d8] mb-1.5">Your name</label>
                    <InputText @bind-Value="Input.Name" id="name"
                               class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-4 py-2.5 text-sm outline-none focus:border-[#7c5cbf] focus:ring-2 focus:ring-[#7c5cbf]/30 transition-all placeholder-white/30"
                               placeholder="Full name" />
                    <ValidationMessage For="() => Input.Name" class="block mt-1.5 text-xs text-red-400" />
                </div>

                <div>
                    <label for="email" class="block text-sm font-medium text-[#c4b8d8] mb-1.5">Email address</label>
                    <InputText @bind-Value="Input.Email" id="email" autocomplete="email"
                               class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-4 py-2.5 text-sm outline-none focus:border-[#7c5cbf] focus:ring-2 focus:ring-[#7c5cbf]/30 transition-all placeholder-white/30"
                               placeholder="you@example.com" />
                    <ValidationMessage For="() => Input.Email" class="block mt-1.5 text-xs text-red-400" />
                </div>

                <div>
                    <label for="phone" class="block text-sm font-medium text-[#c4b8d8] mb-1.5">Phone <span class="text-[#5e4d73]">(optional)</span></label>
                    <InputText @bind-Value="Input.Phone" id="phone"
                               class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-4 py-2.5 text-sm outline-none focus:border-[#7c5cbf] focus:ring-2 focus:ring-[#7c5cbf]/30 transition-all placeholder-white/30"
                               placeholder="+1 (555) 000-0000" />
                    <ValidationMessage For="() => Input.Phone" class="block mt-1.5 text-xs text-red-400" />
                </div>

                <div class="flex items-center gap-3 py-1">
                    <InputCheckbox @bind-Value="Input.ChatResponseOk" id="ChatResponseOk"
                                   class="w-4 h-4 rounded border-white/20 bg-[#291d38] accent-[#7c5cbf] cursor-pointer" />
                    <label for="ChatResponseOk" class="text-sm text-[#9b8eb5] cursor-pointer select-none">
                        Chat response is OK
                    </label>
                </div>
            </div>

            <button type="submit"
                    class="mt-6 w-full bg-[#6c5fc7] hover:bg-[#7c6fd7] text-white font-semibold rounded-lg py-2.5 px-4 text-sm transition-colors shadow-lg shadow-[#6c5fc7]/20">
                Submit request
            </button>
        </EditForm>
    </div>
}
</div>


@code {
    private string? _statusMessage;
    private string _alertClass = "alert-success";

    [Parameter]
    public string? DeviceId { get; init; }

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private void CloseAlert()
    {
        _statusMessage = null;
    }

    private async Task OnValidSubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(DeviceId))
        {
            return;
        }

        var deviceResult = await DataService.GetDevice(DeviceId);
        if (!deviceResult.IsSuccess)
        {
            _alertClass = "alert-danger";
            _statusMessage = "Device not found.";
            return;
        }

        var orgId = deviceResult.Value.OrganizationID;

        var alertParts = new string[]
        {
            $"{Input.Name} is requesting support.",
            $"Device ID: {DeviceId}",
            $"Email: {Input.Email}.",
            $"Phone: {Input.Phone}.",
            $"Chat OK: {Input.ChatResponseOk}."
        };

        var alertMessage = string.Join("  ", alertParts);
        await DataService.AddAlert(DeviceId, orgId, alertMessage);

        var orgUsers = await DataService.GetAllUsersInOrganization(orgId);
        var emailMessage = string.Join("<br />", alertParts);
        foreach (var user in orgUsers)
        {
            if (string.IsNullOrWhiteSpace(user.Email))
            {
                continue;
            }
            await EmailSender.SendEmailAsync(user.Email, "Support Request", emailMessage);
        }

        _alertClass = "alert-success";
        _statusMessage = "We got it!  Someone will contact you soon.";
    }

    private class InputModel
    {
        [StringLength(150)]
        [Required]
        public string Name { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        public string? Phone { get; set; }
        public bool ChatResponseOk { get; set; }
    }
}
