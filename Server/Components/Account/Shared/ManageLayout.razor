@inherits LayoutComponentBase
@layout AccountLayout

<div class="min-h-screen bg-[#0e0819]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

        <div class="mb-6">
            <h1 class="text-white text-2xl font-semibold tracking-tight">Account settings</h1>
            <p class="text-[#9b8eb5] text-sm mt-1">Manage your profile, security, and preferences.</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-6">
            <div class="w-full sm:w-48 flex-shrink-0">
                <ManageNavMenu />
            </div>
            <div class="flex-1 min-w-0">
                @Body
            </div>
        </div>

    </div>
</div>
