@using Microsoft.AspNetCore.Identity
@using Remotely.Server.Data

@inject SignInManager<RemotelyUser> SignInManager

<nav class="bg-[#1d1330] border border-white/10 rounded-xl p-2">
    <NavLink class="manage-nav-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-[#9b8eb5] hover:bg-white/5 hover:text-[#d8d0ec] transition-colors"
             href="Account/Manage" Match="NavLinkMatch.All"
             ActiveClass="bg-[#6c5fc7]/20 text-[#b09aff]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        Profile
    </NavLink>
    <NavLink class="manage-nav-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-[#9b8eb5] hover:bg-white/5 hover:text-[#d8d0ec] transition-colors"
             href="Account/Manage/Email"
             ActiveClass="bg-[#6c5fc7]/20 text-[#b09aff]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Email
    </NavLink>
    <NavLink class="manage-nav-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-[#9b8eb5] hover:bg-white/5 hover:text-[#d8d0ec] transition-colors"
             href="Account/Manage/ChangePassword"
             ActiveClass="bg-[#6c5fc7]/20 text-[#b09aff]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
        </svg>
        Password
    </NavLink>
    @if (hasExternalLogins)
    {
        <NavLink class="manage-nav-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-[#9b8eb5] hover:bg-white/5 hover:text-[#d8d0ec] transition-colors"
                 href="Account/Manage/ExternalLogins"
                 ActiveClass="bg-[#6c5fc7]/20 text-[#b09aff]">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            External logins
        </NavLink>
    }
    <NavLink class="manage-nav-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-[#9b8eb5] hover:bg-white/5 hover:text-[#d8d0ec] transition-colors"
             href="Account/Manage/TwoFactorAuthentication"
             ActiveClass="bg-[#6c5fc7]/20 text-[#b09aff]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        Two-factor auth
    </NavLink>
    <NavLink class="manage-nav-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-[#9b8eb5] hover:bg-white/5 hover:text-[#d8d0ec] transition-colors"
             href="Account/Manage/PersonalData"
             ActiveClass="bg-[#6c5fc7]/20 text-[#b09aff]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Personal data
    </NavLink>
</nav>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
