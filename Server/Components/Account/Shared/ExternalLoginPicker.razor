@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using Remotely.Server.Data

@inject SignInManager<RemotelyUser> SignInManager
@inject IdentityRedirectManager RedirectManager

@if (externalLogins.Length == 0)
{
    <p class="text-[#9b8eb5] text-xs mt-4 text-center">
        No external authentication services are configured.
    </p>
}
else
{
    <div class="mt-5 pt-5 border-t border-white/10">
        <p class="text-[#9b8eb5] text-xs text-center mb-3">Or continue with</p>
        <form class="flex flex-col gap-2" action="Account/PerformExternalLogin" method="post">
            <AntiforgeryToken />
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
            @foreach (var provider in externalLogins)
            {
                <button type="submit"
                        class="w-full bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] font-medium rounded-lg py-2.5 px-4 text-sm transition-colors"
                        name="provider" value="@provider.Name"
                        title="Sign in with @provider.DisplayName">
                    @provider.DisplayName
                </button>
            }
        </form>
    </div>
}

@code {
    private AuthenticationScheme[] externalLogins = [];

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        externalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToArray();
    }
}
