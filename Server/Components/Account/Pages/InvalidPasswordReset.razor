@page "/Account/InvalidPasswordReset"
@layout AuthPagesLayout

<PageTitle>Invalid Password Reset &mdash; SignalRemote</PageTitle>

<div class="bg-[#1d1330] border border-white/10 rounded-2xl p-8 shadow-2xl text-center">

    <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center mx-auto mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
    </div>

    <h1 class="text-white text-2xl font-semibold mb-2">Invalid reset link</h1>
    <p class="text-[#9b8eb5] text-sm mb-6">The password reset link is invalid or has expired. Please request a new one.</p>

    <a href="/Account/ForgotPassword" class="inline-block bg-[#6c5fc7] hover:bg-[#7c6fd7] text-white font-semibold rounded-lg py-2.5 px-6 text-sm transition-colors">
        Request new link
    </a>

</div>
