@page "/Account/ResetPasswordConfirmation"
@layout AuthPagesLayout

<PageTitle>Password Reset Successful &mdash; SignalRemote</PageTitle>

<div class="bg-[#1d1330] border border-white/10 rounded-2xl p-8 shadow-2xl text-center">

    <div class="w-16 h-16 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mx-auto mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
    </div>

    <h1 class="text-white text-2xl font-semibold mb-3">Password reset successful</h1>
    <p class="text-[#9b8eb5] text-sm leading-relaxed mb-6">
        Your password has been reset. You can now sign in with your new credentials.
    </p>

    <a href="/Account/Login" class="inline-block bg-[#6c5fc7] hover:bg-[#7c6fd7] text-white font-semibold rounded-lg py-2.5 px-6 text-sm transition-colors shadow-lg shadow-[#6c5fc7]/20">
        Sign in
    </a>

</div>
