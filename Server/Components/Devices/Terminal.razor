@inherits AuthComponentBase

<div class="terminal-frame @_terminalOpenClass">
    <div class="terminal-header">
        <div>
            <button class="terminal-button ms-4 bg-[#291d38] hover:bg-[#1d1330] border border-white/10 text-[#c4b8d8] rounded-t-lg px-4 py-2 text-sm transition-colors flex items-center gap-2"
                    @onclick="ToggleTerminalOpen">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span>Terminal</span>
            </button>
        </div>
        <div class="text-end">
            <button class="terminal-button me-4 bg-[#291d38] hover:bg-[#1d1330] border border-white/10 text-[#c4b8d8] rounded-t-lg px-4 py-2 text-sm transition-colors flex items-center gap-2"
                    @onclick="ShowQuickScripts">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <span>Quick Scripts</span>
            </button>
        </div>
    </div>

    <div class="terminal-body border border-white/10 bg-[#0e0819]">
        <div @ref="_terminalWindow" class="terminal-window px-2 py-1">
            @foreach (var line in TerminalStore.TerminalLines)
            {
                <div @key="line.Id" class="ml-1 terminal-line @line.ClassName" title="@line.Title">
                    @line.Text
                </div>
            }
        </div>
        <div>
            <div class="terminal-input-area px-2 mb-2">
                <div>
                    <button class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] rounded-lg px-2 py-1.5 text-xs transition-colors"
                            style="align-self: center"
                            @onclick="ShowTerminalHelp">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                        </svg>
                    </button>
                </div>
                <div>
                    <select @bind="_shell"
                            class="bg-[#291d38] border border-white/10 text-white rounded-lg px-2 py-1.5 text-sm outline-none focus:border-[#7c5cbf] transition-all w-full">
                        @foreach (var shell in Enum.GetValues(typeof(ScriptingShell)))
                        {
                            <option @key="shell" value="@shell">@shell</option>
                        }
                    </select>
                </div>
                <div>
                    <input @ref="_terminalInput"
                           class="w-full bg-[#1d1330] border border-white/10 text-white rounded-lg px-3 py-1.5 text-sm outline-none focus:border-[#7c5cbf] font-mono placeholder-white/30"
                           placeholder="Enter a terminal command"
                           spellcheck="false"
                           autocomplete="off"
                           @bind="InputText"
                           @bind:event="oninput"
                           @onkeypress="EvaluateInputKeypress"
                           @onkeydown="EvaluateKeyDown" />
                </div>
            </div>
        </div>
    </div>
</div>
