@inherits AuthComponentBase

<div class="terminal-frame @_terminalOpenClass">
    <div class="terminal-header">
        <div>
            <button class="terminal-button ms-4 flex items-center gap-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 hover:text-slate-100 text-sm px-3 py-1.5 rounded-t-lg transition-colors border-b-0"
                    @onclick="ToggleTerminalOpen">
                <i class="fas fa-terminal text-xs"></i>
                <span>Terminal</span>
            </button>
        </div>
        <div class="text-end">
            <button class="terminal-button me-4 flex items-center gap-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 hover:text-slate-100 text-sm px-3 py-1.5 rounded-t-lg transition-colors border-b-0 ml-auto"
                    @onclick="ShowQuickScripts">
                <i class="fas fa-scroll text-xs"></i>
                <span>Quick Scripts</span>
            </button>
        </div>
    </div>

    <div class="terminal-body border border-slate-700 bg-slate-900">
        <div @ref="_terminalWindow" class="terminal-window px-2 py-1">
            @foreach (var line in TerminalStore.TerminalLines)
            {
                <div @key="line.Id" class="ms-1 terminal-line @line.ClassName" title="@line.Title">
                    @line.Text
                </div>
            }
        </div>
        <div>
            <div class="terminal-input-area px-2 mb-2">
                <div>
                    <button class="btn btn-sm btn-secondary me-1"
                            style="align-self: center" 
                            @onclick="ShowTerminalHelp">
                        <i class="fas fa-question text-xs"></i>
                    </button>
                </div>
                <div>
                    <select @bind="_shell" class="form-control">
                        @foreach (var shell in Enum.GetValues(typeof(ScriptingShell)))
                        {
                            <option @key="shell" value="@shell">@shell</option>
                        }
                    </select>
                </div>
                <div>
                    <input @ref="_terminalInput" 
                           class="form-control" 
                           placeholder="Enter a terminal command"
                           spellcheck="false"
                           autocomplete="off"
                           @bind="InputText" 
                           @bind:event="oninput" 
                           @onkeypress="EvaluateInputKeypress"
                           @onkeydown="EvaluateKeyDown" />
                </div>
            </div>
        </div>
    </div>
</div>
