@attribute [Authorize]
@inherits AuthComponentBase

<h3 class="text-white text-xl font-semibold mb-4">Devices</h3>

<div @onclick="ClearSelectedCard">
    <div id="deviceControlsWrapper">
        <div>
            <div>
                <div class="text-[#9b8eb5] text-xs font-medium mb-1">Device Group</div>
                <div class="flex items-center gap-1.5">
                    <select class="bg-[#291d38] border border-white/10 text-white rounded-lg px-2 py-1.5 text-sm outline-none focus:border-[#7c5cbf] transition-all" style="width: 150px" @bind="_selectedGroupId">
                        <option value="@_deviceGroupAll">All</option>
                        <option value="@_deviceGroupNone">None</option>
                        @foreach (var group in _deviceGroups)
                        {
                            <option @key="group.ID" value="@group.ID">@group.Name</option>
                        }
                    </select>
                    <button class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] rounded-lg px-2 py-1.5 text-xs transition-colors" title="Wake Devices in Group" style="width: 34px;" @onclick="WakeDevices">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mx-auto" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 2a8 8 0 100 16 8 8 0 000-16zm0 14a6 6 0 110-12 6 6 0 010 12z" clip-rule="evenodd"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="mt-2">
                <div class="text-[#9b8eb5] text-xs font-medium mb-1">Sort</div>
                <div class="flex items-center gap-1.5">
                    <select class="bg-[#291d38] border border-white/10 text-white rounded-lg px-2 py-1.5 text-sm outline-none focus:border-[#7c5cbf] transition-all" style="width: 150px" @bind="_selectedSortProperty">
                        <option value=""></option>
                        @foreach (var prop in _sortableProperties)
                        {
                            <option value="@prop.Name">@GetDisplayName(prop)</option>
                        }
                    </select>
                    <button class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] rounded-lg px-2 py-1.5 text-xs transition-colors" title="Sort Direction" style="width: 34px;" @onclick="ToggleSortDirection">
                        <span class="@GetSortIcon() text-xs mx-auto block text-center">⇅</span>
                    </button>
                </div>
            </div>

            <div class="flex items-center gap-2 mt-2">
                <input id="hideOfflineDevicesCheckbox" type="checkbox" class="accent-[#7c5cbf] cursor-pointer w-4 h-4" @bind="_hideOfflineDevices" />
                <label class="text-[#9b8eb5] text-sm cursor-pointer select-none" for="hideOfflineDevicesCheckbox">Hide offline devices</label>
            </div>
            <div class="flex gap-2 mt-2">
                <button class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] font-medium rounded-lg py-1.5 px-3 text-xs transition-colors" @onclick="SelectAllCards">Select All</button>
                <button class="bg-[#6c5fc7] hover:bg-[#7c6fd7] text-white font-semibold rounded-lg py-1.5 px-3 text-xs transition-colors" @onclick="HandleRefreshClicked">Refresh</button>
            </div>
        </div>

        <div>
            <div class="text-right">
                <div>
                    <div class="text-[#9b8eb5] text-xs font-medium mb-1">Search</div>
                    <input class="bg-[#291d38] border border-white/10 text-white rounded-lg px-3 py-1.5 text-sm outline-none focus:border-[#7c5cbf] transition-all placeholder-white/30"
                           style="width: 200px"
                           placeholder="Search device properties"
                           @bind="_filter" />
                </div>

                <div class="flex items-center justify-end gap-1.5 mt-2">
                    <button class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] rounded-lg px-2 py-1 text-xs transition-colors" @onclick="PageDown">
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                    </button>
                    <span class="text-[#9b8eb5] text-xs">Page</span>
                    <input id="currentPageInput" class="bg-[#291d38] border border-white/10 text-white rounded-lg text-center text-xs py-1 outline-none focus:border-[#7c5cbf] transition-all" style="width:55px" pattern="[0-9]" @bind="_currentPage" @bind:event="oninput" />
                    <span class="text-[#9b8eb5] text-xs">of @TotalPages</span>
                    <button class="bg-[#291d38] hover:bg-white/10 border border-white/10 text-[#c4b8d8] rounded-lg px-2 py-1 text-xs transition-colors" @onclick="PageUp">
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                    </button>
                </div>

                <div class="flex items-center justify-end gap-1.5 mt-2">
                    <select class="bg-[#291d38] border border-white/10 text-white rounded-lg px-2 py-1.5 text-xs outline-none focus:border-[#7c5cbf] transition-all" style="width:90px" @bind="_devicesPerPage">
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                    </select>
                    <span class="text-[#9b8eb5] text-xs">per page</span>
                </div>
            </div>
        </div>
    </div>
    <div id="deviceListDiv" class="p-2 mb-5">
        @foreach (var device in DisplayedDevices)
        {
            <CascadingValue Value="this">
                <DeviceCard @key="device.ID" Device="device" />
            </CascadingValue>
        }
    </div>

    <Terminal />
</div>