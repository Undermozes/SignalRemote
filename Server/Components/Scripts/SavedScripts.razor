@inherits AuthComponentBase
@attribute [Authorize]

<div class="outer-grid mt-3 auto-height">
    <EditForm Model="_selectedScript" OnValidSubmit="OnValidSubmit" class="h-100 pb-3">
        <div class="h-100 left-outer-grid">
            <div>
                <div class="flex flex-wrap gap-4 items-start">
                    <DataAnnotationsValidator />

                    <div class="w-full">
                        <ValidationSummary />
                    </div>

                    <div class="w-full">
                        <AlertBanner Message="@_alertMessage" OnClose="() => _alertMessage = string.Empty" />
                    </div>

                    <div class="mt-2 flex-1 min-w-[200px]">
                        <label class="block text-xs font-medium text-[#9b8eb5] mb-1">Shell</label>
                        <InputSelect class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-3 py-2 text-sm outline-none focus:border-[#7c5cbf] transition-all" DisplayName="Shell" @bind-Value="_selectedScript.Shell">
                            @foreach (var shell in Enum.GetValues<ScriptingShell>())
                            {
                                <option @key="@shell" value="@shell">@shell</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => _selectedScript.Shell" />
                    </div>

                    <div class="mt-2 flex-1 min-w-[200px]">
                        <label class="block text-xs font-medium text-[#9b8eb5] mb-1">Script Name</label>
                        <InputText class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-3 py-2 text-sm outline-none focus:border-[#7c5cbf] transition-all" DisplayName="Script Name" @bind-Value="_selectedScript.Name" placeholder="Script name" />
                        <ValidationMessage For="() => _selectedScript.Name" />
                    </div>

                    <div class="mt-2 flex-1 min-w-[200px]">
                        <label class="block text-xs font-medium text-[#9b8eb5] mb-1">Folder Path</label>
                        <InputText class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-3 py-2 text-sm outline-none focus:border-[#7c5cbf] transition-all" DisplayName="Folder Path" @bind-Value="_selectedScript.FolderPath" placeholder="Example: or/portland/quick burger #5" />
                        <ValidationMessage For="() => _selectedScript.FolderPath" />
                    </div>

                    <div class="mt-2 flex-1 min-w-[200px]">
                        <label class="block text-xs font-medium text-[#9b8eb5] mb-1">Public?</label>
                        <br />
                        <InputCheckbox DisplayName="Public?" @bind-Value="_selectedScript.IsPublic" />
                        <ValidationMessage For="() => _selectedScript.IsPublic" />
                    </div>
                    <div class="mt-2 flex-1 min-w-[200px]">
                        <label class="block text-xs font-medium text-[#9b8eb5] mb-1">Quick Script?</label>
                        <br />
                        <InputCheckbox DisplayName="Quick Script?" @bind-Value="_selectedScript.IsQuickScript" />
                        <ValidationMessage For="() => _selectedScript.IsQuickScript" />
                    </div>
                    <div class="mt-2 flex-1 min-w-[200px]">
                        <label class="block text-xs font-medium text-[#9b8eb5] mb-1">Creator</label>
                        <br />
                        <input class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-3 py-2 text-sm outline-none" readonly value="@_selectedScript.Creator?.UserName" />
                    </div>
                    <div class="mt-2 w-full flex items-center gap-2">
                        <button class="bg-[#6c5fc7] hover:bg-[#7c6fd7] text-white font-semibold rounded-lg py-2 px-4 text-sm transition-colors"
                                type="submit"
                                disabled="@(!CanModifyScript)">
                            Save
                        </button>

                        <button class="bg-emerald-500/90 hover:bg-emerald-500 text-white font-semibold rounded-lg py-2 px-4 text-sm transition-colors" type="button" @onclick="CreateNew">
                            New
                        </button>
                        <button class="bg-red-500/90 hover:bg-red-500 text-white font-semibold rounded-lg py-2 px-4 text-sm transition-colors"
                                type="button"
                                disabled="@(!CanDeleteScript)"
                                @onclick="DeleteSelectedScript">
                            Delete
                        </button>
                    </div>
                    <div class="mt-2 w-full flex items-center gap-1">
                        <button type="button" class="text-[#8b6cf7] hover:text-[#a88cff] text-sm underline-offset-2 hover:underline transition-colors me-3" @onclick="ToggleAlertOptionsShown">
                            Alert Options
                        </button>
                        <button type="button" class="text-[#8b6cf7] hover:text-[#a88cff] text-sm underline-offset-2 hover:underline transition-colors" @onclick="ToggleEnvironmentVarsShown">
                            Environment Variables
                        </button>
                    </div>
                    <div class="my-2 w-full collapse @_alertOptionsShowClass">
                        <h5 class="text-[#c4b8d8] text-sm font-semibold mb-2 flex items-center gap-2">
                            <span class="me-2">On Error</span>
                            <button class="bg-[#3d2f5c] hover:bg-[#4d3f6c] text-[#c4b8d8] rounded px-2 py-1 text-xs transition-colors" type="button" @onclick="ShowAlertErrorHelp">
                                <span class="oi oi-question-mark" />
                            </button>
                        </h5>
                        <div class="flex flex-wrap gap-4 items-start">
                            <div class="mt-2 flex-1 min-w-[200px]">
                                <label class="block text-xs font-medium text-[#9b8eb5] mb-1">Send Email</label>
                                <br />
                                <InputCheckbox DisplayName="Send Email on Error" @bind-Value="_selectedScript.SendEmailOnError" />
                                <ValidationMessage For="() => _selectedScript.SendEmailOnError" />
                                <br />
                                to
                                <br />
                                <InputText type="email"
                                           class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-3 py-2 text-sm outline-none focus:border-[#7c5cbf] transition-all"
                                           disabled="@(!_selectedScript.SendEmailOnError)"
                                           DisplayName="Send Error Email To"
                                           @bind-Value="_selectedScript.SendErrorEmailTo" />
                                <ValidationMessage For="() => _selectedScript.SendErrorEmailTo" />
                            </div>
                            <div class="mt-2 flex-1 min-w-[200px]">
                                <label class="block text-xs font-medium text-[#9b8eb5] mb-1">Generate Alert</label>
                                <br />
                                <InputCheckbox DisplayName="Alert on Error" @bind-Value="_selectedScript.GenerateAlertOnError" />
                                <ValidationMessage For="() => _selectedScript.GenerateAlertOnError" />
                            </div>
                        </div>
                    </div>
                    <div class="my-2 w-full collapse @_environmentVarsShowClass">
                        <h5 class="text-[#c4b8d8] text-sm font-semibold mb-2">Environment Variables</h5>
                        <div class="flex flex-wrap gap-4 items-start">
                            <div class="mt-2 flex-1 min-w-[200px]">
                                <div class="block text-xs font-medium text-[#9b8eb5] mb-1">Device ID</div>
                                <div class="text-[#5e4d73] text-xs mt-1">The device ID (GUID) of the computer currently running the script.</div>
                                <input type="text" readonly class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-3 py-2 text-sm outline-none" value="DeviceId" />
                            </div>
                            <div class="mt-2 flex-1 min-w-[200px]">
                                <div class="block text-xs font-medium text-[#9b8eb5] mb-1">Server URL</div>
                                <div class="text-[#5e4d73] text-xs mt-1">The URL of the server that the device connects to (e.g. https://app.example.com).</div>
                                <input type="text" readonly class="w-full bg-[#291d38] border border-white/10 text-white rounded-lg px-3 py-2 text-sm outline-none" value="ServerUrl" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="h100">
                <InputTextArea @bind-Value="_selectedScript.Content"
                               DisplayName="Script Input"
                               class="h-100 w-100"
                               spellcheck="false"
                               autocomplete="off"
                               placeholder="Enter script text here" />
                <ValidationMessage For="() => _selectedScript.Content" />
            </div>
        </div>
    </EditForm>
    <div class="tree-view-wrapper-grid h-100 pb-3">
        <div>
            <h5 class="text-[#c4b8d8] text-sm font-semibold mb-2">Saved Scripts</h5>
            <div>
                <input type="checkbox" class="accent-[#7c5cbf] cursor-pointer w-4 h-4 mr-1" @bind="ParentPage.ShowOnlyMyScripts" />
                <span class="text-[#c4b8d8] text-sm align-top">Show only mine</span>
            </div>
        </div>
        <TreeView DataSource="ParentPage.TreeNodes"
                  ItemTypeSelector="x => x.ItemType"
                  ItemHeaderSelector="x => x.Name"
                  ItemSelected="ScriptSelected"
                  ChildItemSelector="x => x.ChildItems"
                  ItemIconCssSelector="ParentPage.GetItemIconCss"
                  KeySelector="x => x.Id"
                  WrapperStyle="border: 1px solid gray; padding: .5em; height: 100%; border-radius: 5px;"
                  T="ScriptTreeNode" />
    </div>
</div>